{
  "info": {
    "name": "musician website merch/music/orders",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "merch",
      "item": [
        {
          "name": "list products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/",
              "host": ["{{base_url}}"],
              "path": ["api", "products", ""]
            }
          }
        },
        {
          "name": "filter products by category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/?category=t-shirts",
              "host": ["{{base_url}}"],
              "path": ["api", "products", ""],
              "query": [{"key": "category", "value": "t-shirts"}]
            }
          }
        },
        {
          "name": "search merch",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/?search=oversize",
              "host": ["{{base_url}}"],
              "path": ["api", "products", ""],
              "query": [{"key": "search", "value": "oversize"}]
            }
          }
        }
      ]
    },
    {
      "name": "music",
      "item": [
        {
          "name": "list releases",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/releases/",
              "host": ["{{base_url}}"],
              "path": ["api", "releases", ""]
            }
          }
        },
        {
          "name": "get featured releases",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/releases/featured/",
              "host": ["{{base_url}}"],
              "path": ["api", "releases", "featured", ""]
            }
          }
        },
        {
          "name": "get release tracks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/releases/{{release_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "releases", "{{release_id}}", ""]
            }
          }
        }
      ]
    },
    {
      "name": "orders",
      "item": [
        {
          "name": "create order from cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""]
            },
            "description": "Создает заказ для текущего авторизованного пользователя на основе его корзины."
          }
        },
        {
          "name": "list my orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", ""]
            }
          }
        },
        {
          "name": "cancel order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}/cancel/",
              "host": ["{{base_url}}"],
              "path": ["api", "orders", "{{order_id}}", "cancel", ""]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "release_id",
      "value": "1"
    },
    {
      "key": "order_id",
      "value": "1"
    }
  ]
}